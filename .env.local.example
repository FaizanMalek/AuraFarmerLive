NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Min 16 chars. Used to sign the HttpOnly "already voted this session" cookie.
# Generate e.g.: openssl rand -hex 24
VOTE_COOKIE_SECRET=replace-with-a-long-random-string

# Optional — The Guardian Open Platform API key (free at open-platform.theguardian.com).
# Falls back to "test" key (low rate limits) if not set.
GUARDIAN_API_KEY=your-guardian-api-key

# Resend email API — for "suggest a figure" form notifications.
# Sign up free at resend.com → API Keys → Create key.
# Then verify aurafarmer.live domain (Resend dashboard → Domains → Add domain → follow DNS steps on Hostinger).
RESEND_API_KEY=re_xxxxxxxx
# Optional — defaults to "Aura Farmer <noreply@aurafarmer.live>"
# RESEND_FROM=Aura Farmer <noreply@aurafarmer.live>
